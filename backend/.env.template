# OpenAI — https://platform.openai.com/api-keys (when set, used instead of Groq)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini
# Defaults to OPENAI_MODEL if unset (same model for compaction summaries)
# OPENAI_COMPACT_MODEL=gpt-5.4-mini
# Reasoning effort for GPT-5.x (Responses API): none, low, medium, high, xhigh
# OPENAI_REASONING_EFFORT=xhigh

# Groq — https://console.groq.com/keys
GROQ_API_KEY=
# See https://console.groq.com/docs/models (tool-capable models work best here)
GROQ_MODEL=llama-3.3-70b-versatile
# Used when the main model hits TPM/payload limits (HTTP 413): summarizes tool outputs so the run can continue
# GROQ_COMPACT_MODEL=moonshotai/kimi-k2-instruct-0905
# GROQ_CONTEXT_COMPACT_MAX_PASSES=5
# GROQ_COMPACT_PARSE_RETRIES=3

# Logging: DEBUG shows full Python snippets passed to run_python_script
LOG_LEVEL=INFO

# Groq 429 retries — https://console.groq.com/docs/rate-limits
# GROQ_429_MAX_RETRIES=64
# Max seconds to sleep per retry (retry-after and token reset are capped to this)
# GROQ_429_MAX_SLEEP_SEC=600
# Set to 1 for extra LangGraph node traces (very noisy)
# IFC_AGENT_GRAPH_DEBUG=0

# WebSocket server (python -m src.server or uvicorn src.server:app)
# IFC_AGENT_WS_HOST=127.0.0.1
# IFC_AGENT_WS_PORT=8765

# Skip Groq: WebSocket session uses existing IFC + *_issues.json under output/ (no inference).
# IFC_AGENT_SAMPLE_MODE=1
# Optional override (default: ARK_NordicLCA_Housing_Timber_As-built_Archicad.ifc)
# IFC_AGENT_SAMPLE_OUTPUT_IFC_BASENAME=ARK_NordicLCA_Housing_Timber_As-built_Archicad.ifc

# buildingSMART Data Dictionary (bSDD) — optional; see Documentation/bSDD API.md in buildingSMART/bSDD
# BSDD_REST_BASE=https://api.bsdd.buildingsmart.org
# GraphQL (properties + allowedValues). Default is the public test endpoint; production requires auth.
# BSDD_GRAPHQL_URL=https://test.bsdd.buildingsmart.org/graphql/
# BSDD_TOOL_MAX_CHARS=16000
